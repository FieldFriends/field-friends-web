{
  "extends": "@tsconfig/node22/tsconfig.json",
  "include": [
    "vite.config.*",
    "vitest.config.*",
    "cypress.config.*",
    "nightwatch.conf.*",
    "playwright.config.*",
    "shared/**/*",
    "api/**/*",
  ],
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": [
      "node"
    ],
    "paths": {
      "@vercel/node": [
        "./node_modules/@vercel/node/dist/index.d.ts"
      ],
      "@shared/*": [
        "./shared/*"
      ],
      "@api/*": [
        "./api/*"
      ]
    }
  }
}